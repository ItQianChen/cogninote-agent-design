<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itqianchen.agentdesign.mapper.test.TestDatabaseMapper">

    <delete id="deleteChatMessages">
        DELETE FROM chat_messages
    </delete>

    <delete id="deleteChatSessions">
        DELETE FROM chat_sessions
    </delete>

    <delete id="deleteChunks">
        DELETE FROM chunks
    </delete>

    <delete id="deleteDocuments">
        DELETE FROM documents
    </delete>

    <delete id="deleteKnowledgeFolders">
        DELETE FROM knowledge_folders
    </delete>

    <delete id="deleteModelConfigs">
        DELETE FROM model_configs
    </delete>

    <delete id="deleteLegacyModelConfig">
        DELETE FROM model_config
    </delete>

    <select id="findAnyKnowledgeFolderId" resultType="java.lang.String">
        SELECT id FROM knowledge_folders LIMIT 1
    </select>
</mapper>
