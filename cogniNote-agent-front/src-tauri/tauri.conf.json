{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CogniNote",
  "version": "0.1.0",
  "identifier": "com.itqianchen.cogninote",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../../target/desktop/backend/CogniNoteBackend/": "backend/CogniNoteBackend/"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "signCommand": {
        "cmd": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "../../scripts/sign-windows-artifact.ps1",
          "-FilePath",
          "%1"
        ]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
